{
  "name": "webspresso",
  "version": "0.0.1",
  "description": "Minimal, production-ready SSR framework for Node.js with file-based routing, Nunjucks templating, built-in i18n, and CLI tooling",
  "main": "index.js",
  "bin": {
    "webspresso": "./bin/webspresso.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release": "release-it"
  },
  "keywords": [
    "ssr",
    "nunjucks",
    "express",
    "file-based-routing",
    "i18n",
    "framework"
  ],
  "author": "cond",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/everytools/webspresso.git"
  },
  "files": [
    "index.js",
    "bin/",
    "src/"
  ],
  "dependencies": {
    "commander": "^11.1.0",
    "express": "^4.18.2",
    "inquirer": "^8.2.6",
    "nunjucks": "^3.2.4"
  },
  "peerDependencies": {
    "dotenv": "^16.0.0"
  },
  "peerDependenciesMeta": {
    "dotenv": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.2.0",
    "chokidar": "^3.5.3",
    "dotenv": "^16.3.1",
    "release-it": "^17.11.0",
    "supertest": "^6.3.4",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
