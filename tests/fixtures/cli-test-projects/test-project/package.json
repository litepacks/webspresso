{
  "name": "test-project",
  "version": "1.0.0",
  "description": "Webspresso project",
  "main": "server.js",
  "scripts": {
    "dev": "npm run watch:css & node --watch server.js",
    "start": "npm run build:css && NODE_ENV=production node server.js",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/style.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./public/css/style.css --watch"
  },
  "dependencies": {
    "webspresso": "*",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.35",
    "autoprefixer": "^10.4.17"
  }
}
