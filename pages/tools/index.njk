{% extends "layout.njk" %}

{% block content %}
<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="text-center mb-12">
    <h1 class="font-display text-4xl font-bold text-ink-900 mb-4">
      {{ t('tools.title') or 'Developer Tools' }}
    </h1>
    <p class="text-xl text-ink-600 max-w-2xl mx-auto">
      {{ t('tools.description') or 'A collection of useful tools to boost your productivity.' }}
    </p>
  </div>
  
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {% for tool in tools %}
    <a href="{{ fsy.url('/tools/' + tool.slug) }}" class="group bg-white rounded-2xl p-6 border border-ink-100 hover:border-brand-300 hover:shadow-xl transition-all">
      <div class="w-12 h-12 bg-{{ tool.color or 'brand' }}-100 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
        <span class="text-2xl">{{ tool.icon or '🔧' }}</span>
      </div>
      <h3 class="font-display text-xl font-semibold text-ink-900 mb-2 group-hover:text-brand-600 transition-colors">
        {{ tool.name }}
      </h3>
      <p class="text-ink-600 text-sm">
        {{ tool.description }}
      </p>
      <div class="mt-4 flex items-center gap-2 text-brand-600 font-medium text-sm opacity-0 group-hover:opacity-100 transition-opacity">
        {{ t('tools.tryNow') or 'Try now' }}
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none">
          <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </a>
    {% else %}
    <div class="col-span-full text-center py-12">
      <p class="text-ink-500">{{ t('tools.empty') or 'No tools available yet.' }}</p>
    </div>
    {% endfor %}
  </div>
</div>
{% endblock %}


