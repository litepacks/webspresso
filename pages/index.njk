{% extends "layout.njk" %}

{% block content %}
<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <!-- Hero Section -->
  <div class="text-center mb-16">
    <div class="inline-flex items-center gap-2 bg-brand-50 text-brand-700 px-4 py-2 rounded-full text-sm font-medium mb-6">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M13 2L3 14H12L11 22L21 10H12L13 2Z" fill="currentColor"/>
      </svg>
      {{ t('hero.badge') or 'Production-ready SSR' }}
    </div>
    
    <h1 class="font-display text-5xl sm:text-6xl font-bold text-ink-900 mb-6 leading-tight">
      {{ t('hero.title') or 'Build Fast, Ship Faster' }}
    </h1>
    
    <p class="text-xl text-ink-600 max-w-2xl mx-auto mb-8">
      {{ t('hero.description') or 'Webspresso is a minimal, file-based SSR framework for Node.js. Blade-like templating with Nunjucks, automatic routing, and built-in i18n.' }}
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/tools" class="inline-flex items-center gap-2 bg-brand-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-brand-700 shadow-lg shadow-brand-500/25 transition-all">
        {{ t('hero.cta') or 'Explore Tools' }}
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="/about" class="inline-flex items-center gap-2 bg-white text-ink-700 px-6 py-3 rounded-lg font-semibold hover:bg-ink-50 border border-ink-200 transition-all">
        {{ t('hero.secondary') or 'Learn More' }}
      </a>
    </div>
  </div>
  
  <!-- Features Grid -->
  <div class="grid md:grid-cols-3 gap-8 mb-16">
    <div class="bg-white rounded-2xl p-8 border border-ink-100 hover:border-brand-200 hover:shadow-lg transition-all">
      <div class="w-12 h-12 bg-brand-100 rounded-xl flex items-center justify-center mb-4">
        <svg class="w-6 h-6 text-brand-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 7V17C3 18.1046 3.89543 19 5 19H19C20.1046 19 21 18.1046 21 17V7" stroke="currentColor" stroke-width="2"/>
          <path d="M21 7L12 13L3 7" stroke="currentColor" stroke-width="2"/>
          <path d="M3 7L12 1L21 7" stroke="currentColor" stroke-width="2"/>
        </svg>
      </div>
      <h3 class="font-display text-xl font-semibold text-ink-900 mb-2">{{ t('features.routing.title') or 'File-Based Routing' }}</h3>
      <p class="text-ink-600">{{ t('features.routing.description') or 'Create pages by adding .njk files. Dynamic params with [slug], catch-all with [...rest].' }}</p>
    </div>
    
    <div class="bg-white rounded-2xl p-8 border border-ink-100 hover:border-brand-200 hover:shadow-lg transition-all">
      <div class="w-12 h-12 bg-brand-100 rounded-xl flex items-center justify-center mb-4">
        <svg class="w-6 h-6 text-brand-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-width="2"/>
          <path d="M2 12H22" stroke="currentColor" stroke-width="2"/>
          <path d="M12 2C14.5013 4.73835 15.9228 8.29203 16 12C15.9228 15.708 14.5013 19.2616 12 22C9.49872 19.2616 8.07725 15.708 8 12C8.07725 8.29203 9.49872 4.73835 12 2Z" stroke="currentColor" stroke-width="2"/>
        </svg>
      </div>
      <h3 class="font-display text-xl font-semibold text-ink-900 mb-2">{{ t('features.i18n.title') or 'Built-in i18n' }}</h3>
      <p class="text-ink-600">{{ t('features.i18n.description') or 'JSON-based translations with automatic locale detection. Global and route-level overrides.' }}</p>
    </div>
    
    <div class="bg-white rounded-2xl p-8 border border-ink-100 hover:border-brand-200 hover:shadow-lg transition-all">
      <div class="w-12 h-12 bg-brand-100 rounded-xl flex items-center justify-center mb-4">
        <svg class="w-6 h-6 text-brand-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 6V12L16 14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
        </svg>
      </div>
      <h3 class="font-display text-xl font-semibold text-ink-900 mb-2">{{ t('features.hooks.title') or 'Lifecycle Hooks' }}</h3>
      <p class="text-ink-600">{{ t('features.hooks.description') or 'Hook into request lifecycle with beforeLoad, afterRender, and more. Global or per-route.' }}</p>
    </div>
  </div>
  
  <!-- Quick Start -->
  <div class="bg-ink-900 rounded-2xl p-8 text-white">
    <h2 class="font-display text-2xl font-bold mb-4">{{ t('quickstart.title') or 'Quick Start' }}</h2>
    <div class="bg-ink-800 rounded-xl p-4 font-mono text-sm overflow-x-auto">
      <code class="text-brand-300">$</code> <code class="text-white">git clone https://github.com/you/webspresso-starter.git</code><br>
      <code class="text-brand-300">$</code> <code class="text-white">cd webspresso-starter && npm install</code><br>
      <code class="text-brand-300">$</code> <code class="text-white">npm run dev</code>
    </div>
  </div>
</div>
{% endblock %}

